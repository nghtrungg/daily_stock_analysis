# GitHub Actions configuration — Vietnam-focused daily analysis
#
# Add the first block in: Repository -> Settings -> Secrets and variables ->
# Actions -> Variables.  Add the second block as Secrets.  Do not commit real
# secret values.  The daily workflow reads Variables before Secrets when both
# use the same name, so set each key in one place only.

# Required repository Variables
STOCK_LIST=VNM.VN
ENABLED_MARKETS=vn
REPORT_LANGUAGE=vi
REPORT_TYPE=simple
MARKET_REVIEW_ENABLED=false
SINGLE_STOCK_NOTIFY=false
TRADING_DAY_CHECK_ENABLED=true
MAX_WORKERS=1
ENABLE_CHIP_DISTRIBUTION=false

# Optional repository Variables
# Set to true only when you deliberately want the scheduled network smoke job.
NETWORK_SMOKE_ENABLED=false
# REPORT_SHOW_LLM_MODEL=true
# ANALYSIS_DELAY=0

# Required Secret — choose one LLM provider supported by the project.
# GEMINI_API_KEY=<your Gemini API key>
#
# Other supported choices (configure only the one you actually use):
# OPENAI_API_KEY=<your OpenAI-compatible API key>
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=<your model name>
# DEEPSEEK_API_KEY=<your DeepSeek API key>
# ANTHROPIC_API_KEY=<your Anthropic API key>

# Optional Secrets — choose one notification channel if you want delivery.
# TELEGRAM_BOT_TOKEN=<bot token>
# TELEGRAM_CHAT_ID=<chat id>
# FEISHU_WEBHOOK_URL=<webhook URL>
# DINGTALK_WEBHOOK_URL=<webhook URL>
# WECHAT_WEBHOOK_URL=<webhook URL>

# Optional Secret for richer news search.
# TAVILY_API_KEYS=<key>
# BOCHA_API_KEYS=<key>
# BRAVE_API_KEYS=<key>

# Vietnam price/ownership and active Buy Up/Sell Down data use the public
# vnstock integration. Foreign/proprietary flow requires the optional sponsor
# vnstock_data package; no additional Vietnam provider secret is injected by
# the daily GitHub Actions workflow.
